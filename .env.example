# Core
NODE_ENV=development

# Web (SEO & canonical URLs) — production: https://voiceai.uz
NEXT_PUBLIC_SITE_URL=https://voiceai.uz
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

# API — Render da DATABASE_URL (Internal Database URL) majburiy; yoki POSTGRES_* + sslmode
# DATABASE_URL=postgresql://...

# API
API_PORT=4000
WORKER_URL=http://127.0.0.1:8001
JWT_SECRET=change-me
# Access token TTL (e.g. 15m, 1h, 7d)
JWT_EXPIRES_IN=7d

# Database
POSTGRES_USER=voiceai
POSTGRES_PASSWORD=voiceai
POSTGRES_DB=voiceai
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379/0

# S3 (AWS)
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=voiceai
S3_REGION=us-east-1
S3_PRESIGN_EXPIRY=3600

# Stripe (placeholder)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Azure TTS
AZURE_TTS_KEY=
AZURE_TTS_REGION=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
